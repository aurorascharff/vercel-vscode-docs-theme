{
  "name": "vercel-docs-theme",
  "displayName": "Vercel Docs Theme",
  "description": "Dark and light themes for VSCode/Cursor matching the Vercel docs syntax highlighting",
  "version": "0.3.0",
  "publisher": "aurorascharff",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aurorascharff/vercel-vscode-docs-theme"
  },
  "homepage": "https://github.com/aurorascharff/vercel-vscode-docs-theme#readme",
  "bugs": {
    "url": "https://github.com/aurorascharff/vercel-vscode-docs-theme/issues"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "vercel",
    "ray.so",
    "cursor",
    "dark",
    "light",
    "theme",
    "color-theme"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Vercel Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/vercel.json"
      },
      {
        "label": "Vercel Light",
        "uiTheme": "vs",
        "path": "./themes/vercel-light.json"
      }
    ]
  },
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  }
}
